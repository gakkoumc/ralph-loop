# Copy this file to .env, adjust only what you need, then run:
# npm run check
# ./ralph

# Core
RALPH_AGENT_COMMAND=codex exec --full-auto --skip-git-repo-check
RALPH_AGENT_MODE=command
RALPH_PROMPT_FILE=prompts/supervisor.md
RALPH_TASK_CATALOG_FILE=
RALPH_STATE_DIR=state
RALPH_LOG_DIR=logs
RALPH_MAX_ITERATIONS=20
RALPH_IDLE_SECONDS=5
RALPH_TASK_NAME=Codex supervised run

# Panel
RALPH_PANEL_HOST=127.0.0.1
RALPH_PANEL_PORT=8787
# Set both to enable Basic auth. Leaving either side blank keeps the panel open.
RALPH_PANEL_USERNAME=
RALPH_PANEL_PASSWORD=
# Keep this false unless you explicitly want web / Discord to be able to change the shell command.
RALPH_ALLOW_RUNTIME_AGENT_COMMAND_OVERRIDE=false

# Discord
# Leave blank to run in Web only mode.
RALPH_DISCORD_TOKEN=
RALPH_DISCORD_NOTIFY_CHANNEL_ID=
RALPH_DISCORD_DM_USER_ID=
RALPH_DISCORD_APP_NAME=RalphLoop
RALPH_DISCORD_ALLOWED_USER_IDS=
RALPH_DISCORD_GUILD_ID=
RALPH_DISCORD_APPLICATION_ID=
